    m_Localized: Explanation
    m_Metadata:
      m_Items: []
  - m_Id: 50460065960026112
    m_Localized: 3D Authoring
    m_Metadata:
      m_Items: []
  - m_Id: 50461095699406848
    m_Localized: 'Please wait for the analysis result of the system.

      It will
      suggest a suitable 3D instruction and place it at a preliminary location. If
      necessary you can adjust its pose.'
    m_Metadata:
      m_Items: []
  - m_Id: 50467550171226112
    m_Localized: Are you finished with the 3D instructions?
    m_Metadata:
      m_Items: []
  - m_Id: 54385096301412352
    m_Localized: 'VLM

      (proc.)'
    m_Metadata:
      m_Items: []
  - m_Id: 54385409884356608
    m_Localized: Manual
    m_Metadata:
      m_Items: []
  - m_Id: 54456691471003648
    m_Localized: Select a 3D hologram and place it at the desired location
    m_Metadata:
      m_Items: []
  - m_Id: 55224796740349952
    m_Localized: Lefty
    m_Metadata:
      m_Items: []
  - m_Id: 55225000801628160
