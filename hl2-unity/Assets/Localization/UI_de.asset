    m_Metadata:
      m_Items: []
  - m_Id: 26878019012599808
    m_Localized: "Aufl\xF6sung"
    m_Metadata:
      m_Items: []
  - m_Id: 26917472666066944
    m_Localized: 3D Anweisungen
    m_Metadata:
      m_Items: []
  - m_Id: 27692960426921984
    m_Localized: "Scannen Sie zun\xE4chst einen QR-Code. Sobald der QR-Code gr\xFCn
      leuchtet, k\xF6nnen Sie fortfahren."
    m_Metadata:
      m_Items: []
