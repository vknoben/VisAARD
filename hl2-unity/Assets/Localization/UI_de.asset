  - m_Id: 1873348882898944
    m_Localized: '1. Demonstrieren und filmen Sie die Aufgabe

      2. Sagen Sie
      "Stop", um die Aufnahme zu stoppen

      3. Halten Sie das Video kurz, die
      Aktion zentriert'
    m_Metadata:
      m_Items: []
