    m_Metadata:
      m_Items: []
  - m_Id: 28787886676443136
    m_Localized: Zahlen
    m_Metadata:
      m_Items: []
  - m_Id: 28788068906369024
    m_Localized: Symbole
    m_Metadata:
      m_Items: []
  - m_Id: 28788185130532864
