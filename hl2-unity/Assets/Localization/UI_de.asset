      m_Items: []
  - m_Id: 33455657302499328
    m_Localized: Mit dem Erstellen von Anweisungen beginnen
    m_Metadata:
      m_Items: []
  - m_Id: 33455807643131904
    m_Localized: Start
    m_Metadata:
      m_Items: []
  - m_Id: 34121401926000640
    m_Localized: "Das System generiert 3D Anweisungen. \xDCberp\xFCfen Sie, ob diese
      Ihren Erwartungen entsprechen"
    m_Metadata:
      m_Items: []
  - m_Id: 34153148646531072
    m_Localized: "R\xE4umliche Verankerung"
    m_Metadata:
      m_Items: []
  - m_Id: 35626361599078400
    m_Localized: Ok
    m_Metadata:
      m_Items: []
  - m_Id: 35639148387807232
    m_Localized: "Text \xC4ndern"
    m_Metadata:
      m_Items: []
  - m_Id: 35639368811065344
    m_Localized: "Video \xC4ndern"
    m_Metadata:
      m_Items: []
  - m_Id: 35642651810246656
